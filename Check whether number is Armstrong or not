class Main {
    public static void main(String[] args) {
       int num = 153;
        int sum = 0;
        int x=num;
        while (num != 0) {
            int digit = num % 10;
            sum = sum + (digit*digit*digit);
            num = num / 10;
        }
        if(x==sum){
        System.out.println("Armstrong");
        }else{
            System.out.println("not Armstrong");
        }
    }
}
