class Main {
    public static void main(String[] args) {
        int num=121;
        int x=num;
        int rev=0;
        while(num>0){
            int last=num%10;
            rev=rev*10+last;
            num=num/10;
        }
        if(x==rev){
        System.out.println("Palindrome");
        }else{
            System.out.println("Not Palindrome");
        }
    }
}
