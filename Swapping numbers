class Main {
    public static void main(String[] args) {
        int power=30;
        int ninja=20;
        System.out.println("Before swapping:");
        System.out.println("power:"+power);
        System.out.println("ninja:"+ninja);
        
        int bottle=ninja;
        ninja=power;
        power=bottle;
        
        System.out.println("After swapping:");
        System.out.println("power:"+power);
        System.out.println("ninja:"+ninja);
    }
}
