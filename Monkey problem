import java.util.Scanner;
class Main {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int k=sc.nextInt();
        int j=sc.nextInt();
        int m=sc.nextInt();
        int p=sc.nextInt();
         int banana = m / k;
        if (m % k != 0)
            banana++;
        int peanut = p / j;
        if (p % j != 0)
            peanut++;
        int left = n - (banana + peanut);
        System.out.println("Number of Monkeys left on the tree:" + left);
    }
}
      
